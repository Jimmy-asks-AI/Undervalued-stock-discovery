{
  "version": "4.0.0",
  "policy_id": "rebound_window_v4_0_entry_calibration",
  "policy_name_zh": "V4.0 入场确认与概率校准反弹窗口研究",
  "status": "research_only",
  "objective": "在V3.7行业广度概率模型基础上，不再继续调整退出规则，而是测试入场信号的概率边际、确认等待、行业广度修复和下跌延续过滤是否能改善A股反弹窗口识别。",
  "output_dir": "outputs/industry_rebound_window_v4_0_entry_calibration",
  "source_policy_path": "configs/rebound_window_online_state_machine_policy_v2_20.json",
  "v3_7_policy_path": "configs/rebound_window_v3_7_industry_breadth_policy.json",
  "industry_history_dir": "data_catalog/cache/industry_index/history/second",
  "feature_start_date": "2015-01-01",
  "oos_start": "2021-01-01",
  "target_horizon": 20,
  "target_return_threshold": 0.03,
  "target_max_drawdown_floor": -0.04,
  "bad_window_threshold": -0.03,
  "baseline_pressure_conditions": [
    {"field": "market_stress_score", "op": ">=", "value": 0.55},
    {"field": "negative_breadth_60d", "op": ">=", "value": 0.75}
  ],
  "primary_entry_policy_id": "confirmed_probability_repair",
  "entry_selection_policies": [
    {
      "entry_policy_id": "confirmed_probability_repair",
      "entry_policy_name_zh": "概率达标后的广度修复确认",
      "is_primary": true,
      "selection_type": "confirmation_after_raw_model_signal",
      "holding_days": 20,
      "min_confirmation_days": 2,
      "confirmation_window_days": 5,
      "require_model_signal_on_confirmation": true,
      "conditions": [
        {"field": "probability_margin", "op": ">=", "value": 0.0},
        {"field": "breadth_recovery_score", "op": ">=", "value": 0.20},
        {"field": "industry_positive_5d_ratio", "op": ">=", "value": 0.25},
        {"field": "market_return_5d", "op": ">", "value": -0.04},
        {"field": "market_volatility_20d_vs_60d", "op": "<=", "value": 1.45},
        {"field": "industry_new_low_60d_ratio", "op": "<=", "value": 0.70}
      ],
      "description": "先出现V3.7模型信号，再等待2到5个交易日；确认日仍需模型信号有效，并且广度修复、短期市场跌幅、波动和创新低比例没有继续恶化。"
    },
    {
      "entry_policy_id": "loose_confirmation_repair",
      "entry_policy_name_zh": "宽松广度修复确认对照",
      "is_primary": false,
      "selection_type": "confirmation_after_raw_model_signal",
      "holding_days": 20,
      "min_confirmation_days": 1,
      "confirmation_window_days": 5,
      "require_model_signal_on_confirmation": false,
      "conditions": [
        {"field": "probability_margin", "op": ">=", "value": -0.03},
        {"field": "breadth_recovery_score", "op": ">=", "value": 0.10},
        {"field": "industry_positive_5d_ratio", "op": ">=", "value": 0.15},
        {"field": "market_return_5d", "op": ">", "value": -0.05},
        {"field": "market_volatility_20d_vs_60d", "op": "<=", "value": 1.60},
        {"field": "industry_new_low_60d_ratio", "op": "<=", "value": 0.80}
      ],
      "description": "用于观察放松确认条件能否增加样本；不作为统一评价主策略。"
    },
    {
      "entry_policy_id": "strict_confirmation_repair",
      "entry_policy_name_zh": "严格广度修复确认对照",
      "is_primary": false,
      "selection_type": "confirmation_after_raw_model_signal",
      "holding_days": 20,
      "min_confirmation_days": 2,
      "confirmation_window_days": 5,
      "require_model_signal_on_confirmation": true,
      "conditions": [
        {"field": "probability_margin", "op": ">=", "value": 0.03},
        {"field": "breadth_recovery_score", "op": ">=", "value": 0.30},
        {"field": "industry_positive_5d_ratio", "op": ">=", "value": 0.35},
        {"field": "market_return_5d", "op": ">", "value": -0.025},
        {"field": "market_volatility_20d_vs_60d", "op": "<=", "value": 1.30},
        {"field": "industry_new_low_60d_ratio", "op": "<=", "value": 0.55}
      ],
      "description": "用于观察更严格的企稳确认是否能降低坏窗口；不作为统一评价主策略。"
    }
  ],
  "model": {
    "model_id": "industry_breadth_logistic_scorecard_v4_0",
    "train_min_rows": 900,
    "purge_days": 25,
    "test_start_year": 2021,
    "test_end_year": 2026,
    "probability_quantile": 0.85,
    "minimum_probability_threshold": 0.50,
    "learning_rate": 0.08,
    "max_iter": 1200,
    "l2": 0.35,
    "positive_weight": 2.0,
    "features": [
      "market_stress_score",
      "negative_breadth_60d",
      "market_drawdown_252d",
      "market_return_5d",
      "market_return_10d",
      "market_return_20d",
      "breadth_repair_5d",
      "stress_release_5d",
      "market_volatility_20d_vs_60d",
      "market_amount_5d_vs_20d",
      "market_amount_20d_vs_120d",
      "liquidity_repair_5d",
      "industry_positive_5d_ratio",
      "industry_positive_10d_ratio",
      "industry_positive_20d_ratio",
      "industry_positive_turn_5d",
      "industry_above_ma20_ratio",
      "industry_above_ma60_ratio",
      "industry_reclaim_ma20_5d",
      "industry_reclaim_ma20_10d",
      "industry_new_low_60d_ratio",
      "industry_new_low_120d_ratio",
      "industry_new_low_60d_relief_5d",
      "industry_deep_drawdown_252d_ratio",
      "industry_drawdown_median_252d",
      "industry_return_20d_dispersion",
      "panic_exhaustion_score",
      "breadth_recovery_score"
    ]
  },
  "promotion_thresholds": {
    "min_signal_dates": 30,
    "min_nonoverlap_events": 8,
    "min_active_years": 3,
    "max_single_year_concentration": 0.45,
    "min_mean_edge_vs_pressure": 0.01,
    "min_event_mean_return": 0.02,
    "min_event_win_rate": 0.60,
    "max_event_bad_window_rate": 0.25,
    "min_oos_target_capture_rate": 0.10
  },
  "research_boundary": "只研究申万行业和行业指数的市场层广度、概率边际和入场确认；不做个股筛选，不加入ETF，不生成交易指令，不使用未来收益、未来行业广度或同日收盘执行。"
}
