{
  "version": "2.23.0",
  "policy_id": "rebound_window_market_state_label_v2_23",
  "policy_name_zh": "V2.23市场状态标签反弹窗口审计",
  "status": "research_only",
  "objective": "停止围绕少数状态机入场点微调，改为审计更长日频样本中的市场状态标签，判断是否存在可泛化的反弹环境。",
  "output_dir": "outputs/industry_rebound_window_market_state_label_v2_23",
  "source_policy_path": "configs/rebound_window_online_state_machine_policy_v2_20.json",
  "history_dir": "data_catalog/cache/industry_index/history/second",
  "horizons": [20, 60, 120],
  "oos_start": "2021-01-01",
  "rolling_window_years": 3,
  "rolling_step_years": 1,
  "state_labels": [
    {
      "state_id": "high_stress_breadth_repair",
      "state_name_zh": "高压力普跌后广度修复",
      "conditions": [
        {"field": "market_stress_score", "op": ">=", "value": 0.55},
        {"field": "negative_breadth_60d", "op": ">=", "value": 0.75},
        {"field": "breadth_repair_5d", "op": ">=", "value": 0.05},
        {"field": "stress_release_5d", "op": ">=", "value": 0.03}
      ]
    },
    {
      "state_id": "high_stress_positive_turn",
      "state_name_zh": "高压力后短期转正",
      "conditions": [
        {"field": "market_stress_score", "op": ">=", "value": 0.55},
        {"field": "negative_breadth_60d", "op": ">=", "value": 0.75},
        {"field": "market_return_5d", "op": ">", "value": 0.0},
        {"field": "stress_release_5d", "op": ">=", "value": 0.0}
      ]
    },
    {
      "state_id": "deep_drawdown_lowvol_repair",
      "state_name_zh": "深回撤低波动修复",
      "conditions": [
        {"field": "market_drawdown_252d", "op": "<=", "value": -0.20},
        {"field": "negative_breadth_60d", "op": ">=", "value": 0.80},
        {"field": "volatility_pressure", "op": "<=", "value": 0.70},
        {"field": "market_return_5d", "op": ">", "value": 0.0},
        {"field": "breadth_repair_5d", "op": ">=", "value": 0.03}
      ]
    },
    {
      "state_id": "extreme_pressure_no_crash",
      "state_name_zh": "极端压力但未继续急跌",
      "conditions": [
        {"field": "market_stress_score", "op": ">=", "value": 0.65},
        {"field": "negative_breadth_60d", "op": ">=", "value": 0.85},
        {"field": "market_return_5d", "op": ">", "value": -0.03},
        {"field": "stress_release_5d", "op": ">=", "value": -0.02}
      ]
    },
    {
      "state_id": "broad_repair_after_capitulation",
      "state_name_zh": "普跌极端后的广度回补",
      "conditions": [
        {"field": "negative_breadth_60d", "op": ">=", "value": 0.85},
        {"field": "breadth_repair_5d", "op": ">=", "value": 0.08},
        {"field": "market_return_5d", "op": ">", "value": 0.0}
      ]
    }
  ],
  "bottom_baseline_conditions": [
    {"field": "market_stress_score", "op": ">=", "value": 0.55},
    {"field": "negative_breadth_60d", "op": ">=", "value": 0.75},
    {"field": "market_drawdown_252d", "op": "<=", "value": -0.15}
  ],
  "bad_window_thresholds": {
    "20": -0.03,
    "60": -0.05,
    "120": -0.08
  },
  "promotion_thresholds": {
    "min_full_dates": 30,
    "min_nonoverlap_events": 8,
    "min_oos_dates": 8,
    "min_mean_edge_vs_all": 0.01,
    "min_mean_edge_vs_baseline": 0.01,
    "min_nonoverlap_mean_return": 0.0,
    "min_oos_mean_return": 0.0,
    "min_win_rate": 0.58,
    "max_bad_window_rate": 0.25,
    "min_positive_rolling_rate": 0.60,
    "max_single_year_concentration": 0.45
  },
  "promotion_rule": "V2.23若通过，也只能说明某类市场状态具有候选反弹环境特征；仍需下一轮转化为实时状态机并做未来样本验证，不能生成交易指令。",
  "research_boundary": "只研究申万行业和行业指数的市场状态标签；不做个股筛选，不加入ETF，不生成买卖指令，不使用未来收益作为触发特征，不根据结果动态扩展规则。"
}
