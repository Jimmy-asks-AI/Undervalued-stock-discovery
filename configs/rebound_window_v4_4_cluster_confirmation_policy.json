{
  "version": "4.4.0",
  "policy_id": "rebound_window_v4_4_cluster_confirmation",
  "policy_name_zh": "V4.4 信号簇内延迟确认反弹窗口研究",
  "status": "research_only",
  "objective": "在V4.3失败状态过滤基础上，测试信号簇内延迟确认是否能避免过早入场，并改善事件级非重叠实时仿真的收益和胜率。",
  "output_dir": "outputs/industry_rebound_window_v4_4_cluster_confirmation",
  "source_policy_path": "configs/rebound_window_online_state_machine_policy_v2_20.json",
  "industry_history_dir": "data_catalog/cache/industry_index/history/second",
  "feature_start_date": "2015-01-01",
  "oos_start": "2021-01-01",
  "target_horizon": 20,
  "target_return_threshold": 0.03,
  "target_max_drawdown_floor": -0.04,
  "bad_window_threshold": -0.03,
  "baseline_pressure_conditions": [
    {"field": "market_stress_score", "op": ">=", "value": 0.55},
    {"field": "negative_breadth_60d", "op": ">=", "value": 0.75}
  ],
  "failure_state_filter": {
    "primary_signal_id": "cluster_confirmed_failure_state_model",
    "min_failure_flags_to_reject": 3,
    "min_train_raw_signals_for_threshold": 30,
    "rules": [
      {"flag_id": "negative_breadth_too_high", "field": "negative_breadth_60d", "direction": "high", "train_raw_quantile": 0.65, "description": "中期下跌广度仍高"},
      {"flag_id": "industry_positive_20d_too_low", "field": "industry_positive_20d_ratio", "direction": "low", "train_raw_quantile": 0.35, "description": "20日上涨行业占比偏低"},
      {"flag_id": "industry_above_ma20_too_low", "field": "industry_above_ma20_ratio", "direction": "low", "train_raw_quantile": 0.35, "description": "行业均线收复不足"},
      {"flag_id": "liquidity_repair_too_low", "field": "market_amount_20d_vs_120d", "direction": "low", "train_raw_quantile": 0.35, "description": "20日成交额相对120日未修复"},
      {"flag_id": "new_low_relief_too_low", "field": "industry_new_low_60d_relief_5d", "direction": "low", "train_raw_quantile": 0.35, "description": "创新低行业缓解不足"},
      {"flag_id": "model_probability_too_low", "field": "model_probability", "direction": "low", "train_raw_quantile": 0.35, "description": "原始模型概率在训练期高概率信号内偏低"}
    ]
  },
  "cluster_confirmation": {
    "min_wait_days": 1,
    "max_wait_days": 5,
    "holding_days": 20,
    "max_failure_flag_count_on_confirm": 1,
    "min_model_probability_margin": 0.0,
    "min_market_return_5d": -0.02,
    "min_industry_positive_5d_ratio": 0.25,
    "description": "过滤信号出现后等待1到5个交易日；确认日仍需过滤信号存在、失败旗标不超过1、模型概率仍高于阈值、5日市场跌幅不低于-2%、5日上涨行业占比不低于25%。"
  },
  "model": {
    "model_id": "industry_breadth_cluster_confirmation_v4_4",
    "train_min_rows": 900,
    "purge_days": 25,
    "test_start_year": 2021,
    "test_end_year": 2026,
    "probability_quantile": 0.85,
    "minimum_probability_threshold": 0.50,
    "learning_rate": 0.08,
    "max_iter": 1200,
    "l2": 0.35,
    "positive_weight": 2.0,
    "features": [
      "market_stress_score",
      "negative_breadth_60d",
      "market_drawdown_252d",
      "market_return_5d",
      "market_return_10d",
      "market_return_20d",
      "breadth_repair_5d",
      "stress_release_5d",
      "market_volatility_20d_vs_60d",
      "market_amount_5d_vs_20d",
      "market_amount_20d_vs_120d",
      "liquidity_repair_5d",
      "industry_positive_5d_ratio",
      "industry_positive_10d_ratio",
      "industry_positive_20d_ratio",
      "industry_positive_turn_5d",
      "industry_above_ma20_ratio",
      "industry_above_ma60_ratio",
      "industry_reclaim_ma20_5d",
      "industry_reclaim_ma20_10d",
      "industry_new_low_60d_ratio",
      "industry_new_low_120d_ratio",
      "industry_new_low_60d_relief_5d",
      "industry_deep_drawdown_252d_ratio",
      "industry_drawdown_median_252d",
      "industry_return_20d_dispersion",
      "panic_exhaustion_score",
      "breadth_recovery_score"
    ]
  },
  "promotion_thresholds": {
    "min_signal_dates": 30,
    "min_nonoverlap_events": 8,
    "min_active_years": 3,
    "max_single_year_concentration": 0.45,
    "min_mean_edge_vs_pressure": 0.01,
    "min_event_mean_return": 0.02,
    "min_event_win_rate": 0.60,
    "max_event_bad_window_rate": 0.25,
    "min_oos_target_capture_rate": 0.10
  },
  "research_boundary": "只研究申万行业和行业指数的市场层广度、失败状态过滤和信号簇内确认；不做个股筛选，不加入ETF，不生成交易指令，不使用测试期未来收益或同日收盘执行。"
}
