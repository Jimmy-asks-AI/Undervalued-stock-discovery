{
  "version": "2.17.0",
  "policy_id": "rebound_window_second_confirmation_v2_17",
  "policy_name_zh": "V2.17二次确认与坏窗口控制审计",
  "status": "research_only",
  "objective": "基于V2.16误报和漏报，测试少量机制驱动的二次确认过滤，重点看能否降低坏窗口而不完全牺牲反弹捕获。",
  "output_dir": "outputs/industry_rebound_window_second_confirmation_v2_17",
  "date_panel_path": "outputs/industry_rebound_window_audit_v2_11/debug/date_level_panel.csv",
  "horizons": [60, 120],
  "bottom_eligible_conditions": [
    {"field": "market_stress_score", "op": ">=", "value": 0.55},
    {"field": "negative_breadth_60d", "op": ">=", "value": 0.75},
    {"field": "market_drawdown_252d", "op": "<=", "value": -0.15},
    {"field": "low_value_oversold_non_trap_count", "op": ">=", "value": 5}
  ],
  "rules": [
    {
      "rule_id": "stress55_breadth75_ret_le75",
      "rule_name_zh": "普跌高压力但收益压力不过热",
      "base_rule_id": "stress55_breadth75",
      "horizon": 60,
      "conditions": [
        {"field": "market_stress_score", "op": ">=", "value": 0.55},
        {"field": "negative_breadth_60d", "op": ">=", "value": 0.75},
        {"field": "return_pressure", "op": "<=", "value": 0.75}
      ]
    },
    {
      "rule_id": "stress55_breadth75_ret_le80",
      "rule_name_zh": "普跌高压力但收益压力未极端",
      "base_rule_id": "stress55_breadth75",
      "horizon": 60,
      "conditions": [
        {"field": "market_stress_score", "op": ">=", "value": 0.55},
        {"field": "negative_breadth_60d", "op": ">=", "value": 0.75},
        {"field": "return_pressure", "op": "<=", "value": 0.80}
      ]
    },
    {
      "rule_id": "stress55_breadth75_nontrap_ge5",
      "rule_name_zh": "普跌高压力且非陷阱低估超跌>=5",
      "base_rule_id": "stress55_breadth75",
      "horizon": 60,
      "conditions": [
        {"field": "market_stress_score", "op": ">=", "value": 0.55},
        {"field": "negative_breadth_60d", "op": ">=", "value": 0.75},
        {"field": "low_value_oversold_non_trap_count", "op": ">=", "value": 5}
      ]
    },
    {
      "rule_id": "capitulation_lowvol_nontrap_ge5",
      "rule_name_zh": "普跌回撤低波动且非陷阱低估超跌>=5",
      "base_rule_id": "capitulation_lowvol",
      "horizon": 120,
      "conditions": [
        {"field": "market_drawdown_252d", "op": "<=", "value": -0.20},
        {"field": "negative_breadth_60d", "op": ">=", "value": 0.80},
        {"field": "volatility_pressure", "op": "<=", "value": 0.70},
        {"field": "low_value_oversold_non_trap_count", "op": ">=", "value": 5}
      ]
    },
    {
      "rule_id": "capitulation_lowvol_ret_le75",
      "rule_name_zh": "普跌回撤低波动且收益压力不过热",
      "base_rule_id": "capitulation_lowvol",
      "horizon": 120,
      "conditions": [
        {"field": "market_drawdown_252d", "op": "<=", "value": -0.20},
        {"field": "negative_breadth_60d", "op": ">=", "value": 0.80},
        {"field": "volatility_pressure", "op": "<=", "value": 0.70},
        {"field": "return_pressure", "op": "<=", "value": 0.75}
      ]
    }
  ],
  "primary_strong_rebound_thresholds": {"60": 0.05, "120": 0.08},
  "bad_window_thresholds": {"60": -0.05, "120": -0.08},
  "promotion_thresholds": {
    "min_events": 6,
    "min_mean_edge_vs_bottom": 0.025,
    "min_precision_edge_vs_bottom": 0.03,
    "min_win_rate": 0.60,
    "max_bad_window_rate": 0.17,
    "max_worst_event_loss": -0.20
  },
  "promotion_rule": "V2.17若通过，只能标记为小样本二次确认候选；必须继续做逐日净值、最大回撤和新增样本验证，不能生成交易指令。",
  "research_boundary": "只研究申万行业和行业指数的事件级二次确认；不做个股筛选，不加入ETF，不生成买卖指令，不把未来收益作为特征，不根据结果动态扩展规则。"
}
