{
  "version": "2.20.0",
  "policy_id": "rebound_window_online_state_machine_v2_20",
  "policy_name_zh": "V2.20逐日在线状态机反弹窗口审计",
  "status": "research_only",
  "objective": "从事件级回放升级为逐日在线状态机，用观察、确认、入场、撤退、冷却流程审计是否能更真实地识别反弹窗口。",
  "output_dir": "outputs/industry_rebound_window_online_state_machine_v2_20",
  "history_dir": "data_catalog/cache/industry_index/history/second",
  "feature_start_date": "2015-01-01",
  "strategies": [
    {
      "strategy_id": "daily_pressure_repair_confirm",
      "strategy_name_zh": "高压力后广度修复确认",
      "horizon": 60,
      "watch_conditions": [
        {"field": "market_stress_score", "op": ">=", "value": 0.55},
        {"field": "negative_breadth_60d", "op": ">=", "value": 0.75}
      ],
      "confirm_conditions": [
        {"field": "market_return_5d", "op": ">", "value": 0.0},
        {"field": "breadth_repair_5d", "op": ">=", "value": 0.05},
        {"field": "stress_release_5d", "op": ">=", "value": 0.03}
      ],
      "min_observation_days": 5,
      "max_observation_days": 20,
      "stop_loss": -0.08,
      "cooldown_days": 60
    },
    {
      "strategy_id": "daily_pressure_positive_confirm",
      "strategy_name_zh": "高压力后10日转正确认",
      "horizon": 60,
      "watch_conditions": [
        {"field": "market_stress_score", "op": ">=", "value": 0.55},
        {"field": "negative_breadth_60d", "op": ">=", "value": 0.75},
        {"field": "market_drawdown_252d", "op": "<=", "value": -0.10}
      ],
      "confirm_conditions": [
        {"field": "market_return_10d", "op": ">", "value": 0.0},
        {"field": "stress_release_5d", "op": ">=", "value": 0.0}
      ],
      "min_observation_days": 10,
      "max_observation_days": 25,
      "stop_loss": -0.08,
      "cooldown_days": 60
    },
    {
      "strategy_id": "daily_capitulation_lowvol_repair",
      "strategy_name_zh": "深回撤低波动修复确认",
      "horizon": 120,
      "watch_conditions": [
        {"field": "market_drawdown_252d", "op": "<=", "value": -0.20},
        {"field": "negative_breadth_60d", "op": ">=", "value": 0.80},
        {"field": "volatility_pressure", "op": "<=", "value": 0.70}
      ],
      "confirm_conditions": [
        {"field": "market_return_5d", "op": ">", "value": 0.0},
        {"field": "breadth_repair_5d", "op": ">=", "value": 0.03}
      ],
      "min_observation_days": 5,
      "max_observation_days": 30,
      "stop_loss": -0.10,
      "cooldown_days": 120
    }
  ],
  "baseline": {
    "cooldown_days": 60,
    "stop_loss": null
  },
  "promotion_thresholds": {
    "min_trades": 8,
    "min_mean_trade_return": 0.0,
    "min_win_rate": 0.60,
    "max_bad_window_rate": 0.20,
    "max_severe_path_rate": 0.20,
    "max_worst_trade_return": -0.12,
    "max_worst_min_nav_loss": -0.12,
    "min_delta_worst_min_nav_loss_vs_baseline": 0.03,
    "min_delta_bad_window_rate_vs_baseline": 0.05
  },
  "bad_window_thresholds": {
    "60": -0.05,
    "120": -0.08
  },
  "promotion_rule": "V2.20若通过，也只能说明逐日在线状态机在历史样本中形成候选流程；仍需未来新增样本、参数冻结和实盘外推验证，不能生成交易指令。",
  "research_boundary": "只研究申万行业和行业指数的逐日在线反弹窗口状态机；不做个股筛选，不加入ETF，不生成买卖指令，不使用未来收益作为触发特征，不根据结果动态扩展规则。"
}
