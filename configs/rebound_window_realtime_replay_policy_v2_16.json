{
  "version": "2.16.0",
  "policy_id": "rebound_window_realtime_replay_v2_16",
  "policy_name_zh": "V2.16目标校准反弹窗口实时回放审计",
  "status": "research_only",
  "objective": "冻结V2.15目标校准候选规则，用事件级非重叠实时回放评估真实可执行窗口质量、坏窗口和漏报机会成本。",
  "output_dir": "outputs/industry_rebound_window_realtime_replay_v2_16",
  "input_versions": [
    "V2.11反弹窗口识别审计",
    "V2.15抄底反弹目标标签校准审计"
  ],
  "date_panel_path": "outputs/industry_rebound_window_audit_v2_11/debug/date_level_panel.csv",
  "candidate_source_path": "outputs/industry_rebound_window_target_calibration_v2_15/top_candidates.csv",
  "candidate_status": "目标校准反弹窗口候选",
  "max_candidate_rules": 2,
  "random_seed": 2160,
  "random_trials": 2000,
  "bottom_eligible_conditions": [
    {"field": "market_stress_score", "op": ">=", "value": 0.55},
    {"field": "negative_breadth_60d", "op": ">=", "value": 0.75},
    {"field": "market_drawdown_252d", "op": "<=", "value": -0.15},
    {"field": "low_value_oversold_non_trap_count", "op": ">=", "value": 5}
  ],
  "bottom_eligible_logic": "any",
  "rules": [
    {
      "rule_id": "stress55_breadth75",
      "rule_name_zh": "压力分>=0.55且60日下跌广度>=75%",
      "horizon": 60,
      "conditions": [
        {"field": "market_stress_score", "op": ">=", "value": 0.55},
        {"field": "negative_breadth_60d", "op": ">=", "value": 0.75}
      ]
    },
    {
      "rule_id": "capitulation_lowvol",
      "rule_name_zh": "普跌回撤但波动压力未极端",
      "horizon": 120,
      "conditions": [
        {"field": "market_drawdown_252d", "op": "<=", "value": -0.20},
        {"field": "negative_breadth_60d", "op": ">=", "value": 0.80},
        {"field": "volatility_pressure", "op": "<=", "value": 0.70}
      ]
    }
  ],
  "primary_strong_rebound_thresholds": {
    "60": 0.05,
    "120": 0.08,
    "252": 0.12
  },
  "bad_window_thresholds": {
    "60": -0.05,
    "120": -0.08,
    "252": -0.12
  },
  "promotion_thresholds": {
    "min_nonoverlap_events": 8,
    "min_nonoverlap_mean_edge_vs_bottom": 0.02,
    "min_nonoverlap_precision_edge_vs_bottom": 0.08,
    "min_nonoverlap_win_rate": 0.58,
    "max_nonoverlap_bad_window_rate": 0.25,
    "max_worst_event_loss": -0.20,
    "max_random_return_pvalue": 0.10,
    "max_random_precision_pvalue": 0.10
  },
  "promotion_rule": "V2.16若通过，只能说明冻结规则在历史事件级回放中形成候选反弹窗口；仍需后续新增样本和完整逐日净值验证，不能生成交易指令。",
  "research_boundary": "只研究申万行业和行业指数的日期层事件级回放；不做个股筛选，不加入ETF，不生成买卖指令，不把未来收益作为特征，不根据结果动态扩展规则。"
}
