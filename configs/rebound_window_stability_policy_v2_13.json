{
  "version": "2.13.0",
  "policy_id": "rebound_window_stability_v2_13",
  "policy_name_zh": "V2.13反弹窗口稳定性审计",
  "status": "research_only",
  "objective": "冻结V2.12日期层市场状态规则，对候选反弹窗口做时间切分、滚动稳定性、压力日期基准和误报风险审计，判断其是否只是全样本压力beta。",
  "output_dir": "outputs/industry_rebound_window_stability_v2_13",
  "input_versions": [
    "V2.11反弹窗口识别审计",
    "V2.12市场状态反弹窗口审计"
  ],
  "horizons": [
    60,
    120,
    252
  ],
  "pressure_baseline_min": 0.65,
  "rolling_window_years": 3,
  "rolling_step_years": 1,
  "random_seed": 2130,
  "top_candidate_rows": 30,
  "time_splits": [
    {
      "split_id": "early_2015_2018",
      "split_name_zh": "早期样本 2015-2018",
      "start": "2015-01-01",
      "end": "2018-12-31",
      "role": "stability_check"
    },
    {
      "split_id": "middle_2019_2022",
      "split_name_zh": "中段样本 2019-2022",
      "start": "2019-01-01",
      "end": "2022-12-31",
      "role": "stability_check"
    },
    {
      "split_id": "recent_2023_2026",
      "split_name_zh": "近年样本 2023-2026",
      "start": "2023-01-01",
      "end": "2026-12-31",
      "role": "recent_check"
    }
  ],
  "rules": [
    {
      "rule_id": "stress55_breadth75",
      "rule_name_zh": "压力分>=0.55且60日下跌广度>=75%",
      "conditions": [
        {"field": "market_stress_score", "op": ">=", "value": 0.55},
        {"field": "negative_breadth_60d", "op": ">=", "value": 0.75}
      ]
    },
    {
      "rule_id": "breadth75_drawdown20",
      "rule_name_zh": "60日下跌广度>=75%且252日市场回撤<=-20%",
      "conditions": [
        {"field": "negative_breadth_60d", "op": ">=", "value": 0.75},
        {"field": "market_drawdown_252d", "op": "<=", "value": -0.20}
      ]
    },
    {
      "rule_id": "capitulation_lowvol",
      "rule_name_zh": "普跌回撤但波动压力未极端",
      "conditions": [
        {"field": "market_drawdown_252d", "op": "<=", "value": -0.20},
        {"field": "negative_breadth_60d", "op": ">=", "value": 0.80},
        {"field": "volatility_pressure", "op": "<=", "value": 0.70}
      ]
    },
    {
      "rule_id": "nontrap5_breadth75",
      "rule_name_zh": "非陷阱低估超跌行业>=5且60日下跌广度>=75%",
      "conditions": [
        {"field": "low_value_oversold_non_trap_count", "op": ">=", "value": 5},
        {"field": "negative_breadth_60d", "op": ">=", "value": 0.75}
      ]
    },
    {
      "rule_id": "low_value8_breadth75",
      "rule_name_zh": "低估超跌行业>=8且60日下跌广度>=75%",
      "conditions": [
        {"field": "low_value_oversold_count", "op": ">=", "value": 8},
        {"field": "negative_breadth_60d", "op": ">=", "value": 0.75}
      ]
    },
    {
      "rule_id": "nontrap3_breadth75_drawdown15",
      "rule_name_zh": "非陷阱>=3且普跌回撤",
      "conditions": [
        {"field": "low_value_oversold_non_trap_count", "op": ">=", "value": 3},
        {"field": "negative_breadth_60d", "op": ">=", "value": 0.75},
        {"field": "market_drawdown_252d", "op": "<=", "value": -0.15}
      ]
    },
    {
      "rule_id": "return60_breadth75_vol70",
      "rule_name_zh": "收益压力高、普跌、波动未极端",
      "conditions": [
        {"field": "return_pressure", "op": ">=", "value": 0.60},
        {"field": "negative_breadth_60d", "op": ">=", "value": 0.75},
        {"field": "volatility_pressure", "op": "<=", "value": 0.70}
      ]
    },
    {
      "rule_id": "current_nontrap_count10",
      "rule_name_zh": "V2.11旧非陷阱触发数>=10对照",
      "conditions": [
        {"field": "low_value_oversold_non_trap_count", "op": ">=", "value": 10}
      ]
    }
  ],
  "primary_strong_rebound_thresholds": {
    "60": 0.05,
    "120": 0.08,
    "252": 0.12
  },
  "bad_window_thresholds": {
    "60": -0.05,
    "120": -0.08,
    "252": -0.12
  },
  "promotion_thresholds": {
    "min_full_samples": 30,
    "min_full_nonoverlap_samples": 8,
    "min_recent_samples": 8,
    "min_recent_nonoverlap_samples": 3,
    "min_full_uplift_vs_pressure_dates": 0.005,
    "min_recent_uplift_vs_pressure_dates": 0.0,
    "min_full_win_rate": 0.55,
    "min_recent_win_rate": 0.50,
    "min_split_positive_uplift_rate": 0.67,
    "min_rolling_positive_uplift_rate": 0.60,
    "max_bad_window_rate": 0.25,
    "max_recent_bad_window_rate": 0.30,
    "max_random_pvalue": 0.10
  },
  "promotion_rule": "V2.13只有在全样本、近年样本、时间切分和滚动窗口均显示相对压力日期稳定提升时，才能把V2.12候选保留为下一阶段研究候选；仍不能生成交易指令。",
  "research_boundary": "只研究申万行业和行业指数的日期层反弹窗口稳定性；不做个股筛选，不加入ETF，不生成买卖指令，不把未来收益作为特征，不根据结果动态扩展规则。"
}
