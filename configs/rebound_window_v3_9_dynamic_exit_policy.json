{
  "version": "3.9.0",
  "policy_id": "rebound_window_v3_9_dynamic_exit",
  "policy_name_zh": "V3.9 动态退出与失败窗口快速撤退研究",
  "status": "research_only",
  "objective": "在V3.7行业广度入场框架基础上，保持入场信号不变，测试预声明的动态退出、风险预算止损和反弹衰退撤退机制，检验是否能提升反弹窗口收益和胜率。",
  "output_dir": "outputs/industry_rebound_window_v3_9_dynamic_exit",
  "source_policy_path": "configs/rebound_window_online_state_machine_policy_v2_20.json",
  "v3_7_policy_path": "configs/rebound_window_v3_7_industry_breadth_policy.json",
  "industry_history_dir": "data_catalog/cache/industry_index/history/second",
  "feature_start_date": "2015-01-01",
  "oos_start": "2021-01-01",
  "target_horizon": 20,
  "target_return_threshold": 0.03,
  "target_max_drawdown_floor": -0.04,
  "bad_window_threshold": -0.03,
  "baseline_pressure_conditions": [
    {"field": "market_stress_score", "op": ">=", "value": 0.55},
    {"field": "negative_breadth_60d", "op": ">=", "value": 0.75}
  ],
  "model": {
    "model_id": "industry_breadth_logistic_scorecard_v3_7_entry_reused",
    "train_min_rows": 900,
    "purge_days": 25,
    "test_start_year": 2021,
    "test_end_year": 2026,
    "probability_quantile": 0.85,
    "minimum_probability_threshold": 0.50,
    "learning_rate": 0.08,
    "max_iter": 1200,
    "l2": 0.35,
    "positive_weight": 2.0,
    "features": [
      "market_stress_score",
      "negative_breadth_60d",
      "market_drawdown_252d",
      "market_return_5d",
      "market_return_10d",
      "market_return_20d",
      "breadth_repair_5d",
      "stress_release_5d",
      "market_volatility_20d_vs_60d",
      "market_amount_5d_vs_20d",
      "market_amount_20d_vs_120d",
      "liquidity_repair_5d",
      "industry_positive_5d_ratio",
      "industry_positive_10d_ratio",
      "industry_positive_20d_ratio",
      "industry_positive_turn_5d",
      "industry_above_ma20_ratio",
      "industry_above_ma60_ratio",
      "industry_reclaim_ma20_5d",
      "industry_reclaim_ma20_10d",
      "industry_new_low_60d_ratio",
      "industry_new_low_120d_ratio",
      "industry_new_low_60d_relief_5d",
      "industry_deep_drawdown_252d_ratio",
      "industry_drawdown_median_252d",
      "industry_return_20d_dispersion",
      "panic_exhaustion_score",
      "breadth_recovery_score"
    ]
  },
  "primary_exit_policy_id": "balanced_risk_budget_exit",
  "dynamic_exit_policies": [
    {
      "exit_policy_id": "balanced_risk_budget_exit",
      "exit_policy_name_zh": "平衡风险预算退出",
      "max_holding_days": 20,
      "stop_loss": -0.035,
      "risk_off_min_days": 4,
      "risk_off_return_ceiling": -0.018,
      "risk_off_breadth_recovery_max": 0.25,
      "risk_off_positive_5d_max": 0.35,
      "profit_activation": 0.055,
      "trailing_drawdown": 0.030,
      "early_profit_min_days": 10,
      "early_profit_return": 0.035,
      "early_profit_breadth_recovery_max": 0.45,
      "execution_lag_days": 1
    },
    {
      "exit_policy_id": "strict_bad_window_exit",
      "exit_policy_name_zh": "严格坏窗口撤退",
      "max_holding_days": 20,
      "stop_loss": -0.030,
      "risk_off_min_days": 3,
      "risk_off_return_ceiling": -0.012,
      "risk_off_breadth_recovery_max": 0.30,
      "risk_off_positive_5d_max": 0.40,
      "profit_activation": 0.050,
      "trailing_drawdown": 0.025,
      "early_profit_min_days": 8,
      "early_profit_return": 0.030,
      "early_profit_breadth_recovery_max": 0.45,
      "execution_lag_days": 1
    },
    {
      "exit_policy_id": "patient_profit_lock_exit",
      "exit_policy_name_zh": "耐心利润保护退出",
      "max_holding_days": 20,
      "stop_loss": -0.045,
      "risk_off_min_days": 6,
      "risk_off_return_ceiling": -0.025,
      "risk_off_breadth_recovery_max": 0.20,
      "risk_off_positive_5d_max": 0.30,
      "profit_activation": 0.070,
      "trailing_drawdown": 0.035,
      "early_profit_min_days": 12,
      "early_profit_return": 0.045,
      "early_profit_breadth_recovery_max": 0.40,
      "execution_lag_days": 1
    }
  ],
  "promotion_thresholds": {
    "min_signal_dates": 30,
    "min_nonoverlap_events": 8,
    "min_active_years": 3,
    "max_single_year_concentration": 0.45,
    "min_mean_edge_vs_pressure": 0.01,
    "min_event_mean_return": 0.02,
    "min_event_win_rate": 0.60,
    "max_event_bad_window_rate": 0.25,
    "min_oos_target_capture_rate": 0.10
  },
  "research_boundary": "只研究申万行业和行业指数的市场层广度、入场后的风险预算和动态退出；不做个股筛选，不加入ETF，不生成交易指令，不使用未来收益、未来行业广度或同日收盘执行。"
}
