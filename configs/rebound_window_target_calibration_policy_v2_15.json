{
  "version": "2.15.0",
  "policy_id": "rebound_window_target_calibration_v2_15",
  "policy_name_zh": "V2.15抄底反弹目标标签校准审计",
  "status": "research_only",
  "objective": "修正V2.11至V2.14的强反弹标签过宽问题，把牛市加速和抄底反弹分开，只评估压力、回撤或普跌之后的反弹窗口捕获能力。",
  "output_dir": "outputs/industry_rebound_window_target_calibration_v2_15",
  "input_versions": [
    "V2.11反弹窗口识别审计",
    "V2.12市场状态反弹窗口审计",
    "V2.13反弹窗口稳定性审计",
    "V2.14压力释放与广度修复审计"
  ],
  "horizons": [
    60,
    120,
    252
  ],
  "pressure_baseline_min": 0.65,
  "rolling_window_years": 3,
  "rolling_step_years": 1,
  "random_seed": 2150,
  "top_candidate_rows": 30,
  "bottom_eligible_conditions": [
    {"field": "market_stress_score", "op": ">=", "value": 0.55},
    {"field": "negative_breadth_60d", "op": ">=", "value": 0.75},
    {"field": "market_drawdown_252d", "op": "<=", "value": -0.15},
    {"field": "low_value_oversold_non_trap_count", "op": ">=", "value": 5}
  ],
  "bottom_eligible_logic": "any",
  "time_splits": [
    {
      "split_id": "early_2015_2018",
      "split_name_zh": "早期样本 2015-2018",
      "start": "2015-01-01",
      "end": "2018-12-31",
      "role": "stability_check"
    },
    {
      "split_id": "middle_2019_2022",
      "split_name_zh": "中段样本 2019-2022",
      "start": "2019-01-01",
      "end": "2022-12-31",
      "role": "stability_check"
    },
    {
      "split_id": "recent_2023_2026",
      "split_name_zh": "近年样本 2023-2026",
      "start": "2023-01-01",
      "end": "2026-12-31",
      "role": "recent_check"
    }
  ],
  "rules": [
    {
      "rule_id": "stress55_breadth75",
      "rule_name_zh": "压力分>=0.55且60日下跌广度>=75%",
      "family": "V2.12静态市场状态",
      "conditions": [
        {"field": "market_stress_score", "op": ">=", "value": 0.55},
        {"field": "negative_breadth_60d", "op": ">=", "value": 0.75}
      ]
    },
    {
      "rule_id": "capitulation_lowvol",
      "rule_name_zh": "普跌回撤但波动压力未极端",
      "family": "V2.12静态市场状态",
      "conditions": [
        {"field": "market_drawdown_252d", "op": "<=", "value": -0.20},
        {"field": "negative_breadth_60d", "op": ">=", "value": 0.80},
        {"field": "volatility_pressure", "op": "<=", "value": 0.70}
      ]
    },
    {
      "rule_id": "nontrap5_breadth75",
      "rule_name_zh": "非陷阱低估超跌行业>=5且60日下跌广度>=75%",
      "family": "V2.12低估超跌市场状态",
      "conditions": [
        {"field": "low_value_oversold_non_trap_count", "op": ">=", "value": 5},
        {"field": "negative_breadth_60d", "op": ">=", "value": 0.75}
      ]
    },
    {
      "rule_id": "oversold_release",
      "rule_name_zh": "非陷阱低估超跌收缩且广度修复",
      "family": "V2.14压力释放",
      "conditions": [
        {"field": "low_value_oversold_non_trap_count_prev1", "op": ">=", "value": 5},
        {"field": "low_value_oversold_non_trap_count_chg1", "op": "<=", "value": 0.0},
        {"field": "negative_breadth_60d_chg1", "op": "<=", "value": -0.05}
      ]
    },
    {
      "rule_id": "stress_down_breadth_high",
      "rule_name_zh": "高压力未继续恶化且仍处普跌",
      "family": "V2.14压力释放",
      "conditions": [
        {"field": "market_stress_score", "op": ">=", "value": 0.55},
        {"field": "market_stress_score_chg1", "op": "<=", "value": 0.0},
        {"field": "negative_breadth_60d", "op": ">=", "value": 0.70}
      ]
    },
    {
      "rule_id": "bottom_pressure_strict",
      "rule_name_zh": "压力条件至少满足两项",
      "family": "目标标签校准对照",
      "min_bottom_condition_count": 2
    }
  ],
  "primary_strong_rebound_thresholds": {
    "60": 0.05,
    "120": 0.08,
    "252": 0.12
  },
  "bad_window_thresholds": {
    "60": -0.05,
    "120": -0.08,
    "252": -0.12
  },
  "promotion_thresholds": {
    "min_full_samples": 30,
    "min_full_nonoverlap_samples": 8,
    "min_recent_samples": 8,
    "min_full_precision_edge_vs_bottom": 0.08,
    "min_recent_precision_edge_vs_bottom": 0.0,
    "min_full_recall": 0.25,
    "min_split_positive_precision_edge_rate": 0.67,
    "min_rolling_positive_precision_edge_rate": 0.60,
    "max_bad_window_rate": 0.25,
    "max_random_precision_pvalue": 0.10
  },
  "promotion_rule": "V2.15若通过，只能说明规则对“压力后的反弹”标签有候选捕获能力；仍需实时仿真净值和未来新增样本验证，不能生成交易指令。",
  "research_boundary": "只研究申万行业和行业指数的日期层抄底反弹标签校准；不做个股筛选，不加入ETF，不生成买卖指令，不把未来收益作为特征，不根据结果动态扩展规则。"
}
