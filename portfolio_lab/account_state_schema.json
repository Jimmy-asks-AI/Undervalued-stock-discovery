{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ETF量化辅助交易账户状态",
  "type": "object",
  "required": ["configured", "as_of_date", "cash", "total_equity", "peak_equity", "max_acceptable_drawdown", "positions"],
  "properties": {
    "configured": {"const": true},
    "as_of_date": {"type": "string", "format": "date"},
    "cash": {"type": "number", "minimum": 0},
    "total_equity": {"type": "number", "exclusiveMinimum": 0},
    "peak_equity": {"type": "number", "exclusiveMinimum": 0},
    "max_acceptable_drawdown": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
    "commission_rate": {"type": "number", "minimum": 0},
    "minimum_commission": {"type": "number", "minimum": 0},
    "positions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["etf_code", "shares", "sellable_shares", "cost_price", "market_price", "entry_date"],
        "properties": {
          "etf_code": {"type": "string", "pattern": "^[0-9]{6}$"},
          "shares": {"type": "integer", "minimum": 0},
          "sellable_shares": {"type": "integer", "minimum": 0},
          "cost_price": {"type": "number", "exclusiveMinimum": 0},
          "market_price": {"type": "number", "exclusiveMinimum": 0},
          "entry_date": {"type": "string", "format": "date"},
          "protective_stop_price": {"type": "number", "exclusiveMinimum": 0},
          "bid_price": {"type": "number", "exclusiveMinimum": 0},
          "ask_price": {"type": "number", "exclusiveMinimum": 0},
          "iopv": {"type": "number", "exclusiveMinimum": 0},
          "average_daily_amount_20d": {"type": "number", "minimum": 0},
          "current_industry_rank": {"type": "integer", "minimum": 1}
        }
      }
    }
  }
}
