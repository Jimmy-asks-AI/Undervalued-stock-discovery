# The research integrity manifests hash exact file bytes.  Force a stable LF
# checkout for text so Windows core.autocrlf cannot invalidate a restored
# cohort after cloning the recovery bundle.
* text=auto eol=lf

# Native Windows launchers, if added later, retain their conventional ending.
*.bat text eol=crlf
*.cmd text eol=crlf

# Content-addressed evidence must survive checkout byte-for-byte.  The
# append-only ledgers, checkpoints, source snapshots, and cohort manifests use
# file SHA256 in addition to logical record hashes.  Suppress text diffs for
# these byte-frozen files so CRLF bytes are not reported as trailing space.
logs/**/*.jsonl -text -eol -diff
logs/**/*.csv -text -eol -diff
logs/**/*.json -text -eol -diff

